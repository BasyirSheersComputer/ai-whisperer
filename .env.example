# Copy to .env and fill in.
DEBUG=true
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/reactivation
REDIS_URL=redis://localhost:6379/0

# Meta WhatsApp Cloud API
META_VERIFY_TOKEN=pick-a-random-string
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=

# true = log sends instead of calling Meta (keep true until WABA is live)
WHATSAPP_DRY_RUN=true

# LLM — leave key empty / dry run true for keyless local dev
ANTHROPIC_API_KEY=
LLM_DRY_RUN=true

# Admin dashboard (required outside debug)
ADMIN_TOKEN=

# Cal.com (leave empty for dry-run slots)
CALCOM_API_KEY=
CALENDAR_DRY_RUN=true

# Optional error tracking
SENTRY_DSN=

# Serverless (Vercel) mode — see docs/VERCEL_DEPLOY.md
CELERY_EAGER=false
CRON_SECRET=
